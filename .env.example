# Copy these keys to Vercel: Project → Settings → Environment Variables
# Add each name and your real value. Use the same values as in .env.local for parity.

# Required for My Shed (items, auth). If missing on Vercel, dashboard can show fewer/wrong items.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for analyze + recommend (item flow)
ANTHROPIC_API_KEY=

# Optional: Near you donation places (Donate confirmation)
GOOGLE_PLACES_API_KEY=

# Optional: curb confirmation uses OpenWeatherMap 5-day/3h forecast when set
OPENWEATHERMAP_API_KEY=

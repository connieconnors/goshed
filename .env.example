# Copy these keys to Vercel: Project → Settings → Environment Variables
# Add each name and your real value. Use the same values as in .env.local for parity.

# Required for My Shed (items, auth). If missing on Vercel, dashboard can show fewer/wrong items.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (same project as above). Dashboard → Settings → API → service_role. Never expose to the client.
# Used by invite accept, account delete, password onboarding, auth callback helpers, etc.
SUPABASE_SERVICE_ROLE_KEY=

# Required for analyze + recommend (item flow)
ANTHROPIC_API_KEY=

# Required for App Store subscriptions.
# iOS App Store builds use the native RevenueCat iOS key in the Expo React Native shell.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=

# Optional web-visible alias for local browser/dev fallback.
NEXT_PUBLIC_REVENUECAT_IOS_API_KEY=

# Optional fallback for non-native web billing/dev. If omitted, NEXT_PUBLIC_REVENUECAT_API_KEY is also supported.
NEXT_PUBLIC_REVENUECAT_WEB_API_KEY=
NEXT_PUBLIC_REVENUECAT_API_KEY=

# Server-only RevenueCat secret key. Required so Supabase-authenticated users unlock Pro after purchase.
REVENUECAT_SECRET_API_KEY=

# Optional: Near you donation places (Donate confirmation)
GOOGLE_PLACES_API_KEY=

# Optional: curb confirmation uses OpenWeatherMap 5-day/3h forecast when set
OPENWEATHERMAP_API_KEY=
